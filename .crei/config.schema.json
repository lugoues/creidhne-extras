{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/lugoues/creidhne/v0/crei.schema.json",
  "title": "Creidhne configuration",
  "description": "Schema for crei.toml. See https://github.com/lugoues/creidhne.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "quadlet_dir": {
      "type": "string",
      "description": "Target directory for generated quadlet unit files (default: ~/.config/containers/systemd)."
    },
    "diff_tool": {
      "type": "string",
      "description": "External diff tool such as \"delta\"; empty uses the built-in differ."
    },
    "diff_style": {
      "type": "string",
      "enum": ["highlight", "plain", "inline"],
      "default": "highlight",
      "description": "How a modified line renders in plan/diff/apply: highlight (pair, changed span emphasized), plain (pair, whole lines colored), or inline (single ~ word-diff line)."
    },
    "reload_systemd": {
      "type": "boolean",
      "description": "Run 'systemctl daemon-reload' after 'crei apply' (default: true)."
    },
    "secrets_field": {
      "type": "string",
      "description": "Top-level CUE field that 'crei secrets' reads the #SecretRegistry from (default: secrets)."
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "description": "Output styles for plan/diff/apply. Each entry is a color string or a table of fg/bg plus attributes.",
      "properties": {
        "header": { "$ref": "#/definitions/style" },
        "text": { "$ref": "#/definitions/style" },
        "context": { "$ref": "#/definitions/style" },
        "inline_context": { "$ref": "#/definitions/style" },
        "add": { "$ref": "#/definitions/style" },
        "remove": { "$ref": "#/definitions/style" },
        "add_char": { "$ref": "#/definitions/style" },
        "remove_char": { "$ref": "#/definitions/style" }
      }
    }
  },
  "definitions": {
    "style": {
      "description": "A color string (foreground), or a table of fg/bg plus attribute toggles.",
      "oneOf": [
        { "$ref": "#/definitions/color" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fg": { "$ref": "#/definitions/color" },
            "bg": { "$ref": "#/definitions/color" },
            "bold": { "type": "boolean" },
            "italic": { "type": "boolean" },
            "underline": { "type": "boolean" },
            "reverse": { "type": "boolean" },
            "strikethrough": { "type": "boolean" },
            "faint": { "type": "boolean" }
          }
        }
      ]
    },
    "color": {
      "type": "string",
      "pattern": "^(|#[0-9a-fA-F]{3}|#[0-9a-fA-F]{6}|[0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])$",
      "description": "Hex color (#rgb or #rrggbb), an ANSI index 0-255, or empty for the terminal default."
    }
  }
}
